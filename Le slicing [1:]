liste: list[int] = [10, 20, 30, 40, 50]

print(liste[1:])    # [20, 30, 40, 50]  -> tout sauf le premier élément
print(liste[:2])    # [10, 20]          -> les deux premiers
print(liste[1:3])   # [20, 30]          -> de l'index 1 à 2 (3 exclu)
print(liste[:])      # [10, 20, 30, 40, 50] -> copie complète
